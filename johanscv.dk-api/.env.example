OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
PORT=8787
JOHANSCV_ACCESS_CODE=choose_a_private_code
# ASK_JOHAN_ACCESS_CODE=choose_a_private_code # deprecated fallback
JWT_SECRET=change_this_to_a_long_random_secret # required in production
SESSION_SECRET=change_this_to_a_different_long_random_secret
ASK_JOHAN_JWT_TTL=7d
ASK_JOHAN_AUTH_COMPAT_MODE=false
ASK_JOHAN_AUTH_FAIL_WINDOW_MS=600000
ASK_JOHAN_AUTH_FAIL_MAX=10
GEOJOHAN_MAPS_API_KEY=
ASK_JOHAN_USAGE_STORE=memory
# REDIS_URL=redis://localhost:6379
# ASK_JOHAN_REDIS_KEY_PREFIX=ask-johan
MAX_QUESTION_CHARS=800
ASK_JOHAN_DAILY_CAP=100
ALLOWED_ORIGINS=https://johanniemann.github.io,https://johanscv.dk,https://www.johanscv.dk
ASK_JOHAN_TIMEOUT_MS=15000
ASK_JOHAN_RATE_LIMIT_WINDOW_MS=60000
ASK_JOHAN_RATE_LIMIT_MAX=30
UPDATES_SIGNUP_RATE_LIMIT_WINDOW_MS=60000
UPDATES_SIGNUP_RATE_LIMIT_MAX=8
UPDATES_SIGNUP_DAILY_CAP=20
RESEND_API_KEY=
RESEND_UPDATES_FROM_EMAIL=
RESEND_UPDATES_REPLY_TO_EMAIL=
RESEND_UPDATES_SEGMENT_ID=
RESEND_TOPIC_PROJECTS_ID=
RESEND_TOPIC_RESUME_ID=
RESEND_TOPIC_INTERACTIVE_SERVICES_ID=
# Shared secret for protected deploy/workflow broadcast triggers
UPDATES_AUTOMATION_TOKEN=
# Optional central endpoint used by local deploy wrappers
# UPDATES_AUTOMATION_ENDPOINT=https://johanscv-api-johu0002-no.azurewebsites.net
# Optional auto-broadcast locale for deploy-triggered mails: dk | en
# UPDATES_BROADCAST_LOCALE=dk
# Optional auto-broadcast site URL override
# UPDATES_BROADCAST_SITE_BASE_URL=https://johanscv.dk
# Optional broadcast store override: memory | file | redis
# UPDATES_BROADCAST_STORE=file
# Optional file path for file-mode broadcast state/log storage
# UPDATES_BROADCAST_STATE_FILE=./.updates-broadcast-state.json
# Optional number of stored broadcast log entries
# UPDATES_BROADCAST_LOG_LIMIT=100
APP_BASE_URL=http://localhost:5173
SPOTIFY_CLIENT_ID=
SPOTIFY_OWNER_REFRESH_TOKEN=
# Optional but recommended for robust artist portrait lookups in development mode:
SPOTIFY_CLIENT_SECRET=
# Optional legacy OAuth callback support (not required for dashboard rendering):
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8787/api/spotify/callback
SPOTIFY_SCOPES=user-read-recently-played
SPOTIFY_SESSION_COOKIE_NAME=johanscv_spotify_sid
SPOTIFY_SESSION_TTL_MS=604800000
SPOTIFY_PKCE_TTL_MS=600000
SPOTIFY_SNAPSHOT_CACHE_TTL_MS=600000
SPOTIFY_REQUEST_TIMEOUT_MS=12000
SPOTIFY_RATE_LIMIT_WINDOW_MS=60000
SPOTIFY_RATE_LIMIT_MAX=20
SPOTIFY_DAILY_CAP=100
JOHAN_CONTEXT_B64=
# Optional alternatives:
# JOHAN_CONTEXT=
# JOHAN_CONTEXT_FILE=./johan-context.private.md
# Optional local Azure CLI deploy helper overrides:
# AZURE_RESOURCE_GROUP=johanscv-rg-no
# AZURE_WEBAPP_NAME=johanscv-api-johu0002-no
